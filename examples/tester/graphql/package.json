{
  "name": "@rockpack/example-tester-graphql",
  "version": "2.0.0",
  "description": "Rockpack example: graphql",
  "license": "ISC",
  "author": "Aleksandrov Sergey <gooddev.sergey@gmail.com> (https://github.com/AlexSergey/rockpack)",
  "main": "index.js",
  "scripts": {
    "build": "cross-env NODE_ENV=production node scripts.build.js",
    "format": "npm run format:code",
    "format:code": "eslint . --fix",
    "lint": "npm run lint:ts && npm run lint:code",
    "lint:code": "eslint .",
    "lint:ts": "tsc --noEmit",
    "start": "cross-env NODE_ENV=development node scripts.build.js",
    "test": "node scripts.tests.js",
    "test:watch": "node scripts.tests.js watch"
  },
  "dependencies": {
    "axios": "1.16.1",
    "axios-mock-adapter": "2.1.0",
    "graphql": "16.14.0",
    "graphql-tag": "2.12.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@rockpack/codestyle": "8.0.0",
    "@rockpack/tester": "8.0.0",
    "@rockpack/tsconfig": "8.0.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2"
  }
}
