{
  "name": "@rockpack/example-tester-rest",
  "version": "1.0.0",
  "description": "Rockpack example: rest",
  "license": "MIT",
  "author": "Aleksandrov Sergey <gooddev.sergey@gmail.com> (https://github.com/AlexSergey/rockpack)",
  "scripts": {
    "build": "cross-env NODE_ENV=production tsx scripts.build.ts",
    "format": "npm run format:code",
    "format:code": "eslint . --fix",
    "lint": "npm run lint:ts && npm run lint:code",
    "lint:code": "eslint .",
    "lint:ts": "tsc --noEmit",
    "start": "cross-env NODE_ENV=development tsx scripts.build.ts",
    "test": "tsx scripts.tests.ts",
    "test:watch": "tsx scripts.tests.ts watch"
  },
  "dependencies": {
    "axios": "1.16.1",
    "axios-mock-adapter": "2.1.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@rockpack/codestyle": "8.0.0",
    "@rockpack/tester": "8.0.0",
    "@rockpack/tsconfig": "8.0.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "tsx": "4.22.3"
  }
}
