{
  "name": "@rockpack/example-compiler-advanced-config-elm-support",
  "version": "1.0.0",
  "description": "Rockpack example: advanced-config-elm-support",
  "license": "MIT",
  "author": "Aleksandrov Sergey <gooddev.sergey@gmail.com> (https://github.com/AlexSergey/rockpack)",
  "scripts": {
    "build": "cross-env NODE_ENV=production tsx scripts.build.ts",
    "format": "npm run format:code",
    "format:code": "eslint . --fix",
    "lint": "npm run lint:ts && npm run lint:code",
    "lint:code": "eslint .",
    "lint:ts": "tsc --noEmit",
    "start": "cross-env NODE_ENV=development tsx scripts.build.ts"
  },
  "dependencies": {
    "elm": "^0.19.1-3",
    "elm-analyse": "0.16.5"
  },
  "devDependencies": {
    "@rockpack/codestyle": "8.0.0",
    "@rockpack/compiler": "8.0.0",
    "@rockpack/tsconfig": "8.0.0",
    "elm-webpack-loader": "8.0.0",
    "tsx": "4.19.4",
    "webpack-notifier": "1.15.0"
  }
}
