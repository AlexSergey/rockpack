{
  "name": "@rockpack/starter",
  "version": "8.0.0",
  "private": false,
  "description": "CLI scaffolding tool for React apps with zero-config CSR and SSR setup, Webpack, Jest, and ESLint",
  "keywords": [
    "cli",
    "scaffolding",
    "react",
    "ssr",
    "csr",
    "webpack",
    "typescript",
    "zero-config",
    "boilerplate",
    "rockpack"
  ],
  "homepage": "https://alexsergey.github.io/rockpack/",
  "bugs": {
    "url": "https://github.com/AlexSergey/rockpack/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexSergey/rockpack.git"
  },
  "license": "MIT",
  "author": "Aleksandrov Sergey <gooddev.sergey@gmail.com> (https://github.com/AlexSergey/rockpack)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./types/bin/index.d.ts",
      "import": "./lib/bin/index.mjs"
    }
  },
  "main": "./lib/bin/index.mjs",
  "module": "./lib/bin/index.mjs",
  "types": "./types/bin/index.d.ts",
  "bin": {
    "rockpack": "./lib/bin/index.mjs"
  },
  "files": [
    "lib",
    "templates",
    "types"
  ],
  "scripts": {
    "build": "npm run clean && tsx scripts.build.ts",
    "clean": "node scripts.clean.mjs",
    "format": "npm run format:code",
    "format:code": "eslint . --fix",
    "lint": "npm run lint:ts && npm run lint:code",
    "lint:code": "eslint .",
    "lint:ts": "tsc --noEmit",
    "production": "npm publish --access public"
  },
  "dependencies": {
    "@inquirer/select": "5.2.0",
    "chalk": "5.6.2",
    "change-case": "5.4.4",
    "deep-extend": "0.6.0",
    "inquirer": "14.0.0",
    "latest-version": "9.0.0",
    "mkdirp": "3.0.1",
    "ncp": "2.0.0",
    "ora": "9.4.0",
    "semver": "7.8.1",
    "sort-package-json": "3.6.1",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "tsx": "4.22.3"
  },
  "engines": {
    "node": ">=23.0.0"
  }
}
