{
  "name": "@rockpack/utils",
  "version": "8.0.0",
  "private": false,
  "description": "Internal utilities shared across Rockpack packages",
  "keywords": [
    "rockpack",
    "utilities"
  ],
  "homepage": "https://alexsergey.github.io/rockpack/",
  "bugs": {
    "url": "https://github.com/AlexSergey/rockpack/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexSergey/rockpack.git"
  },
  "license": "MIT",
  "author": "Aleksandrov Sergey <gooddev.sergey@gmail.com> (https://github.com/AlexSergey/rockpack)",
  "type": "module",
  "exports": {
    ".": {
      "import": "./lib/esm/index.mjs",
      "require": "./lib/cjs/index.cjs",
      "types": "./types/index.d.ts"
    },
    "./polyfills/text-encoder.fix": {
      "import": "./lib/esm/polyfills/text-encoder.fix.mjs",
      "require": "./lib/cjs/polyfills/text-encoder.fix.cjs",
      "types": "./types/polyfills/text-encoder.fix.d.ts"
    }
  },
  "main": "./lib/cjs/index.cjs",
  "module": "./lib/esm/index.mjs",
  "types": "./types/index.d.ts",
  "files": [
    "lib",
    "types"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:types",
    "build:cjs": "node scripts/build.cjs.mjs",
    "build:esm": "node scripts/build.mjs",
    "build:types": "tsc -p tsconfig.types.json",
    "format": "npm run format:code",
    "format:code": "eslint . --fix",
    "lint": "npm run lint:ts && npm run lint:code",
    "lint:code": "eslint .",
    "lint:ts": "tsc --noEmit",
    "production": "npm run lint && npm publish --access public"
  },
  "dependencies": {
    "semver": "7.8.0",
    "valid-types": "2.0.5",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@types/node": "24.10.13",
    "@types/semver": "7.7.1",
    "@types/yargs": "17.0.35"
  },
  "engines": {
    "node": ">=23.0.0"
  }
}
