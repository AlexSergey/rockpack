    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-config-tailwindcss": "1.0.1",
    "stylelint-scss": "7.1.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "yargs": "18.0.0"
