{
  "name": "@rockpack/codestyle",
  "version": "8.0.0",
  "private": false,
  "description": "Opinionated ESLint, Prettier, and Stylelint configuration for React and TypeScript projects",
  "keywords": [
    "eslint",
    "prettier",
    "stylelint",
    "typescript",
    "linting",
    "code-style",
    "react",
    "rockpack"
  ],
  "homepage": "https://alexsergey.github.io/rockpack/",
